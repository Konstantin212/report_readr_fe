{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-verify.cjs",
            "if": "Bash(git commit*)",
            "timeout": 300,
            "statusMessage": "Verifying pnpm typecheck + build before commit…"
          }
        ]
      }
    ]
  }
}
