# Required in Vercel Production and Preview.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
AUTHORIZED_EMAILS="you@example.com,girlfriend@example.com"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional. GitHub sign-in is hidden unless both values are configured.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Local-only bypass for UI development. Never enable this on Vercel.
AUTH_DEMO_MODE="false"
AUTH_DEMO_EMAIL="you@example.com"
