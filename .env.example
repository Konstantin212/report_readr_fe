# Required in Vercel Production and Preview.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
AUTHORIZED_EMAILS="you@example.com,girlfriend@example.com"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional. GitHub sign-in is hidden unless both values are configured.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Local-only bypass for UI development. Never enable this on Vercel.
AUTH_DEMO_MODE="false"
AUTH_DEMO_EMAIL="you@example.com"

CRON_SECRET="generated-by-vercel-when-cron-runs"

# Spot-price provider. Quotes pipeline tries Twelve Data first (works
# from Vercel data-center IPs, which Yahoo blocks and Stooq now
# bot-challenges). Free tier: 800 req/day, batched 8 symbols/call —
# more than enough for ~20 holdings × one daily run.
# Sign up at https://twelvedata.com and paste the key here.
TWELVE_DATA_API_KEY=""
