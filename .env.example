# Required in Vercel Production and Preview.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
AUTHORIZED_EMAILS="you@example.com,girlfriend@example.com"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional. GitHub sign-in is hidden unless both values are configured.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Local-only bypass for UI development. Never enable this on Vercel.
AUTH_DEMO_MODE="false"
AUTH_DEMO_EMAIL="you@example.com"

CRON_SECRET="generated-by-vercel-when-cron-runs"

# Spot-price provider chain. Both are free; both are needed because
# each one's free tier covers different exchanges.
#
# FMP — US stocks (NYSE/NASDAQ/AMEX), unlimited symbols per batched
# call, 250 req/day. Sign up at https://financialmodelingprep.com .
# Without it the orchestrator skips straight to Twelve Data.
FMP_API_KEY=""

# Twelve Data — works from Vercel data-center IPs (Yahoo blocks them,
# Stooq now bot-challenges), covers US + LSE + Xetra + Amsterdam +
# Stockholm. Free tier: 8 credits/min, 800/day. Used here for the
# international tickers FMP free doesn't price.
# Sign up at https://twelvedata.com .
TWELVE_DATA_API_KEY=""
